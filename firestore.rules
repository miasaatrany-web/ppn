rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // System collection for connection test
    match /system/ping {
      allow read: if true;
    }

    // Products collection
    match /products/{productId} {
      allow read: if true; // Publicly readable for the app (can be hardened with auth)
      allow write: if true; // Temporary allow all for simple setup (should be hardened)
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
